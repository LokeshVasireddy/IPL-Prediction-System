   "source": [
    "first_innings_score = (\n",
    "    balls[balls['inning'] == 0]\n",
    "    .groupby('matchId')['current_score']\n",
    "    .max()\n",
    ")\n",
    "balls['target'] = balls['matchId'].map(first_innings_score)\n",
    "balls.loc[balls['inning'] == 1, 'target'] = balls['target'] + 1\n",
    "balls.loc[balls['inning'] == 0, 'target'] = 0"
   ]
