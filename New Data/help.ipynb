   "source": [
    "balls['current_score'] = balls['current_score']/200\n",
    "balls['target'] = balls['target']/200\n",
    "balls['last_over_runs'] = balls['last_over_runs']/200\n",
    "balls['total_balls_in_over'] = balls['total_balls_in_over']/10"
   ]
