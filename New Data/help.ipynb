       "       'phase', 'current_score', 'wickets_fallen', 'target', 'last_over_runs',\n",
       "       'total_balls', 'is_boundary', 'balls_since_boundary',\n",
       "       'percentage_target_achieved', 'venue'],\n",
       "      dtype='object')"
      ]
     },
