   "source": [
    "mask = balls['isNoBall'] > 1\n",
    "\n",
    "balls.loc[mask, 'batsman_runs'] += (balls.loc[mask, 'isNoBall'] - 1)\n",
    "balls.loc[mask, 'isNoBall'] = 1"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "id": "49a99fe8",
   "metadata": {},
   "outputs": [],
   "source": [
    "balls['repeat'] = np.where(balls['isWide'] > 0, balls['isWide'], 1)\n",
    "\n",
    "balls = balls.loc[balls.index.repeat(balls['repeat'])].copy()\n",
    "\n",
    "balls.loc[balls['isWide'] > 0, 'isWide'] = 1\n",
    "\n",
    "balls.drop(columns=['repeat'], inplace=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 26,
   "id": "d00dc71f",
   "metadata": {},
   "outputs": [],
   "source": [
    "balls['is_legal'] = ((balls['isWide'] == 0) & (balls['isNoBall'] == 0)).astype(int)\n",
    "\n",
    "balls['ball'] = (\n",
    "    balls.groupby(['matchId','inning','over'])['is_legal']\n",
    "    .cumsum()\n",
    ")\n",
    "\n",
    "balls['ball'] = balls['ball'].replace(0, np.nan)\n",
    "balls['ball'] = (\n",
    "    balls.groupby(['matchId','inning','over'])['ball']\n",
    "    .ffill()\n",
    "    .fillna(1)\n",
    ")"
   ]
  },
