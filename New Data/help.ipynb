   "metadata": {},
   "outputs": [],
   "source": [
    "max = 2025 - 2008 + 1\n",
    "values = np.arange(1, max+1)\n",
    "mean = np.mean(values)\n",
    "std = np.std(values)\n",
    "\n",
    "balls['season'] = ((balls['season']-2007)-mean)/std"
   ]
  },
